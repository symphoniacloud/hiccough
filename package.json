{
  "name": "@symphoniacloud/hiccough",
  "version": "0.0.0",
  "description": "A Clojure-inspired HTML generation library for JavaScript and TypeScript",
  "license": "MIT",
  "author": {
    "email": "mike@symphonia.io",
    "name": "Mike Roberts",
    "url": "https://symphonia.io"
  },
  "keywords": [
    "html",
    "template",
    "hiccough",
    "browser"
  ],
  "homepage": "https://github.com/symphoniacloud/hiccough",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/symphoniacloud/hiccough.git"
  },
  "bugs": {
    "url": "https://github.com/symphoniacloud/hiccough/issues"
  },
  "type": "module",
  "scripts": {
    "local-checks": "tsc && npm run lint && npm run format && npm run test",
    "lint": "eslint --max-warnings=0 --fix-dry-run \"{src,test}/**/*.{js,ts}\"",
    "format": "prettier --check \"{src,test}/**/*.{js,ts}\"",
    "test": "vitest run",
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "local": "npm run local-checks && npm run build",
    "prepublishOnly": "npm run local"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "@eslint/js": "9.x",
    "@types/node": "22.x",
    "@typescript-eslint/eslint-plugin": "8.x",
    "@typescript-eslint/parser": "8.x",
    "eslint": "9.x",
    "eslint-config-prettier": "10.x",
    "prettier": "3.x",
    "typescript": "5.x",
    "typescript-eslint": "8.x",
    "vitest": "4.x"
  },
  "files": [
    "package.json",
    "README.md",
    "LICENSE",
    "dist/"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  }
}
